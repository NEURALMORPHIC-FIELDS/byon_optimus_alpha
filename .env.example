# BYON World Connector (v10.1 alpha) - example environment. Copy to .env (gitignored).
# Safe defaults: external connectors OFF, final audit + per-user namespace REQUIRED,
# direct memory-service exposure FORBIDDEN.

BYON_GATEWAY_PORT=8090
BYON_MEMORY_SERVICE_URL=http://127.0.0.1:8000
BYON_ORCHESTRATOR_URL=http://127.0.0.1:3000

BYON_ALPHA_MODE=true
BYON_REQUIRE_FINAL_AUDIT=true
BYON_REQUIRE_USER_NAMESPACE=true
BYON_ALLOW_DIRECT_MEMORY_SERVICE=false

BYON_ENABLE_MCP=true
BYON_ENABLE_LIBRECHAT=true
BYON_ENABLE_OPENCLAW=false
BYON_ENABLE_N8N=false

BYON_KILL_SWITCH=false

# Real FCE-M v15.7a is mandatory in BYON's memory-service (resolved at runtime, never bundled).
FCEM_MEMORY_ENGINE_ROOT=/path/to/13_v15_7a_consolidation
FSOAT_REQUIRE_EXTERNAL_FCEM_RUNTIME=true

# Optional alpha access control
# BYON_ALPHA_USER_ALLOWLIST=lucian,friend_01,friend_02
# BYON_ALPHA_SHARED_TOKEN=change-me

# Secrets live in the environment or secrets/ (gitignored), never committed.
# ANTHROPIC_API_KEY=...
