# Normalize line endings: Git stores LF, checks out native on each platform.
* text=auto eol=lf

# Windows-native scripts keep CRLF on checkout
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat model/index artifacts as binary (defensive; they are gitignored anyway)
*.pt   binary
*.faiss binary
